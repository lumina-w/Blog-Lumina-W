---
const BASE = import.meta.env.BASE_URL;
---

<div
  id="loader"
  class="bg-dark fixed inset-0 z-100 flex items-center justify-center transition-opacity duration-500"
>
  <div class="flex flex-col items-center gap-4">
    <img
      src={`${BASE}brand/logo.webp`}
      alt="Lúmina W"
      class="h-12 w-auto animate-pulse"
    />
    <div class="bg-light/10 h-0.5 w-32 overflow-hidden rounded-full">
      <div
        id="loader-bar"
        class="bg-brand h-full w-0 rounded-full transition-all duration-700"
      >
      </div>
    </div>
  </div>
</div>

<script>
  import '@/scripts/loader.ts';
</script>