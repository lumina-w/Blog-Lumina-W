---
interface Props {
  href: string;
  target?: '_blank' | '_self';
  class?: string;
  icon?: string;
  rel?: string;
}

const ICONS_BASE = `${import.meta.env.BASE_URL}icons/ui`;

const { href, target = '_self', class: extra = '', icon, rel } = Astro.props;
---

<a href={href} target={target} class={`link ${extra}`}>
  {
    icon && (
      <img
        src={`${ICONS_BASE}/${icon}.svg`}
        alt=""
        class="h-5 w-5 shrink-0"
      />
    )
  }
  <slot />
</a>