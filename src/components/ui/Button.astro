---
interface Props {
  href?: string;
  target?: '_blank' | '_self';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  icon?: string;
  rel?: string;
}

const ICONS_BASE = `${import.meta.env.BASE_URL}icons/ui`;

const {
  href,
  target = '_self',
  type = 'button',
  class: extra = '',
  icon,
  rel,
} = Astro.props;
---

{
  href ? (
    <a href={href} target={target} rel={rel ? 'noopener noreferrer' : undefined} class={`btn-primary ${extra}`}>
      {icon && (
        <img
          src={`${ICONS_BASE}/${icon}.svg`}
          alt=""
          class="h-5 w-5 shrink-0"
        />
      )}
      <slot />
    </a>
  ) : (
    <button type={type} class={`btn-primary ${extra}`}>
      {icon && (
        <img
          src={`${ICONS_BASE}/${icon}.svg`}
          alt=""
          class="h-5 w-5 shrink-0"
        />
      )}
      <slot />
    </button>
  )
}