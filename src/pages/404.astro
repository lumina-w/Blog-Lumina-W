---
import Layout from '@/layouts/Layout.astro';
import Link from '@/components/ui/Link.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="404 | Página no encontrada">
  <div
    class="bg-page flex min-h-[calc(100vh-64px)] flex-col items-center justify-center gap-6 px-6 text-center"
  >
    <p class="font-display text-brand text-8xl font-bold">404</p>

    <div class="flex flex-col gap-2">
      <h1 class="font-display text-dark text-2xl font-bold">
        Esta página no existe.
      </h1>
      <p class="text-dark text-sm">
        O la movimos, o nunca estuvo aquí. En cualquier caso, te podemos llevar
        de vuelta.
      </p>
    </div>
    <Link href={`${import.meta.env.BASE_URL}`} class="mt-3"
      >Volver al inicio</Link
    >
  </div>
</Layout>